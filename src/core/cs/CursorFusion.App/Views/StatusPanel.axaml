<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:CursorFusion.App.Views"
             x:Class="CursorFusion.App.Views.StatusPanel">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto">

        <!-- 状态栏 -->
        <Border Grid.Row="0" Background="#16213e" CornerRadius="6" Padding="12" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Platform:" Foreground="#888888" FontSize="13" />
                <TextBlock Text="{Binding Platform}" Foreground="#e94560" FontSize="13" FontWeight="Bold" />
            </StackPanel>
        </Border>

        <!-- 鼠标位置 -->
        <Border Grid.Row="1" Background="#16213e" CornerRadius="6" Padding="16" Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="X"
                           Foreground="#888888"
                           FontSize="12"
                           Margin="0,0,0,4" />
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="{Binding MouseX}"
                           Foreground="#e0e0e0"
                           FontSize="28"
                           FontWeight="Bold" />

                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="Y"
                           Foreground="#888888"
                           FontSize="12"
                           Margin="0,0,0,4" />
                <TextBlock Grid.Row="1" Grid.Column="1"
                           Text="{Binding MouseY}"
                           Foreground="#e0e0e0"
                           FontSize="28"
                           FontWeight="Bold" />
            </Grid>
        </Border>

        <!-- 屏幕分辨率 + 光标类型 -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*" Margin="0,0,0,12">
            <Border Background="#16213e" CornerRadius="6" Padding="12" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="Resolution" Foreground="#888888" FontSize="11" />
                    <TextBlock Foreground="#e0e0e0" FontSize="15" FontWeight="Bold">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} x {1}">
                                <Binding Path="ScreenWidth" />
                                <Binding Path="ScreenHeight" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#16213e" CornerRadius="6" Padding="12" Margin="6,0,0,0">
                <StackPanel>
                    <TextBlock Text="Cursor Type" Foreground="#888888" FontSize="11" />
                    <TextBlock Text="{Binding CursorType}"
                               Foreground="#e94560"
                               FontSize="15"
                               FontWeight="Bold" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- 按键状态 -->
        <Border Grid.Row="3" Background="#16213e" CornerRadius="6" Padding="16" Margin="0,0,0,12">
            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*">
                <!-- Left -->
                <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,24,0">
                    <TextBlock Text="Left" Foreground="#888888" FontSize="11" />
                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#e0e0e0"
                               Text="{Binding IsLeftDown, Converter={x:Static views:StatusPanel.BoolToStateConverter}}" />
                </StackPanel>

                <!-- Middle -->
                <StackPanel Grid.Column="2" Spacing="2" Margin="0,0,24,0">
                    <TextBlock Text="Middle" Foreground="#888888" FontSize="11" />
                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#e0e0e0"
                               Text="{Binding IsMiddleDown, Converter={x:Static views:StatusPanel.BoolToStateConverter}}" />
                </StackPanel>

                <!-- Right -->
                <StackPanel Grid.Column="4" Spacing="2">
                    <TextBlock Text="Right" Foreground="#888888" FontSize="11" />
                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#e0e0e0"
                               Text="{Binding IsRightDown, Converter={x:Static views:StatusPanel.BoolToStateConverter}}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 底部状态栏 -->
        <Border Grid.Row="4" Background="#0f3460" CornerRadius="6" Padding="10,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding StatusText}"
                           Foreground="#aab8c2"
                           FontSize="12" />
            </StackPanel>
        </Border>

    </Grid>
</UserControl>