<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CursorFusion.App.ViewModels"
        xmlns:views="clr-namespace:CursorFusion.App.Views"
        x:Class="CursorFusion.App.MainWindow"
        Title="CursorFusion"
        Width="520"
        Height="420"
        MinWidth="420"
        MinHeight="340"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e"
        Foreground="#e0e0e0"
        FontFamily="Inter">

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*" Margin="20">
        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,16">
            <TextBlock Text="CursorFusion"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#e0e0e0" />
            <TextBlock Text="{Binding Version, StringFormat='v{0}'}"
                       FontSize="14"
                       Foreground="#888888"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- Status Panel -->
        <views:StatusPanel Grid.Row="1"
                           DataContext="{Binding}" />
    </Grid>
</Window>