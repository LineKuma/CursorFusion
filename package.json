{
  "name": "cursorfusion",
  "version": "0.1.0-alpha.1",
  "description": "Cross-platform mouse cursor overlay effects tool (C# core, winit rendering, Avalonia UI)",
  "main": "dist/index.js",
  "bin": { "cursorfusion": "./bin/cursorfusion.js" },
  "scripts": {
    "build": "echo 'Build complete' && mkdir -p dist && cp -r src/*.js src/**/*.js dist/ 2>/dev/null || true",
    "test": "jest --coverage --verbose",
    "test:unit": "jest --testPathPattern=__tests__/unit --coverage",
    "test:integration": "jest --testPathPattern=__tests__/integration --coverage",
    "test:e2e": "jest --testPathPattern=__tests__/e2e --no-coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/ __tests__/ --ext .js",
    "format": "prettier --write 'src/**/*.{js,json}' '__tests__/**/*.{js,json}'",
    "format:check": "prettier --check 'src/**/*.{js,json}' '__tests__/**/*.{js,json}'",
    "pkg": "node scripts/build-binary.js"
  },
  "keywords": ["cursor", "overlay", "effects", "desktop"],
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/LineCatOvO/CursorFusion.git"
  },
  "author": "LineCatOvO",
  "engines": { "node": ">=18" },
  "devDependencies": {
    "@jest/globals": "^29.7",
    "eslint": "^9",
    "jest": "^29.7",
    "prettier": "^3"
  }
}